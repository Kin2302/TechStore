@using Microsoft.AspNetCore.Identity
@using Application.Interfaces.Orders
@inject ICartService CartService
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechStore</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav id="mainNavbar" class="navbar navbar-expand-lg navbar-dark tech-navbar sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-warning" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-microchip"></i> TechStore
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <form class="d-flex mx-auto my-2 my-lg-0 tech-search-form" asp-controller="Home" asp-action="Search" method="get">
                        <input class="form-control me-2 tech-search-input" type="search" name="q" placeholder="Tìm kiếm linh kiện..." aria-label="Search">
                        <button class="btn btn-outline-warning" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
                    </form>

                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>

                        <li class="nav-item mx-2">
                            <a class="nav-link position-relative btn border-0 text-white tech-cart-link" asp-controller="Compare" asp-action="Index" title="So sánh sản phẩm">
                                <i class="fa-solid fa-code-compare fa-lg"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-info" id="compareCount">
                                    0
                                </span>
                            </a>
                        </li>

                        <li class="nav-item mx-2">
                            <a class="nav-link position-relative btn border-0 text-white tech-cart-link" asp-controller="Wishlist" asp-action="Index" title="Yêu thích">
                                <i class="fa-regular fa-heart fa-lg"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="wishlistCount">
                                    0
                                </span>
                            </a>
                        </li>

                        <li class="nav-item mx-2">
                            <a class="nav-link position-relative btn border-0 text-white tech-cart-link" asp-controller="Cart" asp-action="Index">
                                <i class="fa-solid fa-cart-shopping fa-lg"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cartCount">
                                    @(CartService.GetCartCount())
                                </span>
                            </a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-user-circle fa-lg text-success"></i>
                                    @User.Identity?.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <span class="dropdown-item-text text-muted small">
                                            <i class="fa-solid fa-envelope"></i> @UserManager.GetUserAsync(User).Result?.Email
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Order" asp-action="MyOrders"><i class="fa-solid fa-box"></i> Đơn hàng của tôi</a></li>
                                    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="fa-solid fa-gear"></i> Quản lý tài khoản</a></li>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="fa-solid fa-shield"></i> Admin Panel</a></li>
                                    }

                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-user-circle fa-lg"></i> Tài khoản
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Login"><i class="fa-solid fa-right-to-bracket"></i> Đăng nhập</a></li>
                                    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Register"><i class="fa-solid fa-user-plus"></i> Đăng ký</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @{ 
        var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
        var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
        // hide category sidebar on Wishlist, Cart, Search and Compare pages to avoid duplicate sidebars
        var hideSidebar = string.Equals(controller, "Wishlist", System.StringComparison.OrdinalIgnoreCase)
                          || string.Equals(controller, "Cart", System.StringComparison.OrdinalIgnoreCase)
                          || string.Equals(controller, "Compare", System.StringComparison.OrdinalIgnoreCase)
                          || (string.Equals(controller, "Home", System.StringComparison.OrdinalIgnoreCase)
                              && string.Equals(action, "Search", System.StringComparison.OrdinalIgnoreCase));
    }

    <div class="container-fluid layout-main">
        <main role="main" class="pb-3 pt-3">
            @RenderBody()
        </main>
    </div>

    <footer class="tech-footer text-white text-center py-3 mt-auto">
        <div class="container">
            &copy; 2026 - TechStore (Nhóm 4) - <a href="#" class="text-warning">Privacy</a>
        </div>
    </footer>

    <!-- Chat Widget -->
    <div class="chat-widget">
        <div class="chat-button" onclick="toggleChat()">
            <i class="fa-solid fa-robot fa-xl"></i>
        </div>

        <div class="chat-window" id="chatWindow">
            <div class="chat-header d-flex justify-content-between align-items-center">
                <span><i class="fa-solid fa-microchip me-2"></i>TechStore AI</span>
                <button type="button" class="btn-close btn-close-white btn-sm" onclick="toggleChat()"></button>
            </div>

            <div class="chat-body" id="chatBody">
                <div class="chat-message bot">
                    <div class="message-content">
                        👋 Xin chào! Tôi là AI tư vấn linh kiện.<br>
                        Bạn có thể hỏi về linh kiện hoặc mô tả dự án cần làm!
                    </div>
                </div>
            </div>

            <div class="chat-footer">
                <div class="input-group">
                    <input type="text" class="form-control" id="chatInput"
                           placeholder="Nhập câu hỏi..."
                           onkeypress="if(event.key==='Enter') sendMessage()">
                    <button class="btn btn-primary" onclick="sendMessage()">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        (function () {
            const navbar = document.getElementById('mainNavbar');
            if (!navbar) return;
            const onScroll = () => {
                if (window.scrollY > 8) navbar.classList.add('scrolled');
                else navbar.classList.remove('scrolled');
            };
            window.addEventListener('scroll', onScroll, { passive: true });
            onScroll();
        })();

        function loadCompareCount() {
            fetch('/Compare/GetCount')
                .then(r => r.json())
                .then(data => {
                    const el = document.getElementById('compareCount');
                    if (el) el.textContent = data.count ?? 0;
                });
        }

        loadCompareCount();
        
        function loadWishlistCount() {
            fetch('/Wishlist/GetCount')
                .then(r => r.json())
                .then(data => {
                    const el = document.getElementById('wishlistCount');
                    if (el) el.textContent = data.count ?? 0;
                });
        }

        loadWishlistCount();

        function loadCartCount() {
            // try to get count from server endpoint first
            fetch('/Cart/GetCartCount')
                .then(r => r.json())
                .then(data => {
                    const el = document.getElementById('cartCount');
                    if (el) el.textContent = data.count ?? 0;
                })
                .catch(() => {
                    // fallback: render server-side count injected into layout
                    try {
                        const serverCount = parseInt('@(CartService.GetCartCount())');
                        const el = document.getElementById('cartCount');
                        if (el) el.textContent = isNaN(serverCount) ? 0 : serverCount;
                    } catch (e) { }
                });
        }

        loadCartCount();

        async function toggleWishlist(productId, add) {
            const url = add ? '/Wishlist/Add' : '/Wishlist/Remove';
            const form = new FormData();
            form.append('productId', productId);

            const res = await fetch(url, { method: 'POST', body: form, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            try {
                const data = await res.json();
                const el = document.getElementById('wishlistCount');
                if (el) el.textContent = data.count ?? data.count ?? 0;
            } catch { }
        }

        // Sync wishlist buttons (heart icons) with server session
        async function syncWishlistButtons() {
            try {
                const res = await fetch('/Wishlist/GetIds');
                const ids = await res.json();
                if (!Array.isArray(ids)) return;

                document.querySelectorAll('.wishlist-btn').forEach(btn => {
                    const pid = parseInt(btn.getAttribute('data-product-id'));
                    const icon = btn.querySelector('i');
                    if (!icon) return;
                    if (ids.includes(pid)) {
                        icon.classList.remove('fa-regular');
                        icon.classList.add('fa-solid', 'text-danger');
                    } else {
                        icon.classList.remove('fa-solid', 'text-danger');
                        icon.classList.add('fa-regular');
                    }
                });
            } catch (e) {
                // ignore
            }
        }

        // run after DOM ready and keep handlers delegated so they work for dynamic content
        $(function () {
            syncWishlistButtons();

            // Delegated click handler for wishlist buttons
            $(document).on('click', '.wishlist-btn', async function (e) {
                e.preventDefault();
                var btn = $(this);
                var productId = btn.data('product-id');

                try {
                    const form = new URLSearchParams();
                    form.append('productId', productId);

                    const res = await fetch('/Wishlist/Add', {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: form
                    });
                    const data = await res.json();
                    if (data.success) {
                        $('#wishlistCount').text(data.count);
                        var icon = btn.find('i');
                        icon.removeClass('fa-regular').addClass('fa-solid text-danger');
                    } else {
                        alert(data.message || 'Không thể thêm vào yêu thích.');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Không thể kết nối tới server.');
                }
            });
        });

        function toggleChat() {
            var chatWindow = document.getElementById("chatWindow");
            if (chatWindow.style.display === "none" || chatWindow.style.display === "") {
                chatWindow.style.display = "flex";
                document.getElementById("chatInput").focus();
            } else {
                chatWindow.style.display = "none";
            }
        }

        async function sendMessage() {
            const input = document.getElementById('chatInput');
            const message = input.value.trim();
            if (!message) return;

            const chatBody = document.getElementById('chatBody');

            chatBody.innerHTML += `
                <div class="chat-message user">
                    <div class="message-content">${escapeHtml(message)}</div>
                </div>`;
            input.value = '';
            chatBody.scrollTop = chatBody.scrollHeight;

            const typingId = 'typing-' + Date.now();
            chatBody.innerHTML += `
                <div class="chat-message bot" id="${typingId}">
                    <div class="message-content">
                        <div class="typing-indicator">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                </div>`;
            chatBody.scrollTop = chatBody.scrollHeight;

            try {
                const response = await fetch('/api/Chat/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: message })
                });

                const data = await response.json();
                document.getElementById(typingId)?.remove();

                chatBody.innerHTML += `
                    <div class="chat-message bot">
                        <div class="message-content">${formatResponse(data.reply || data.error || 'Có lỗi xảy ra')}</div>
                    </div>`;
            } catch (error) {
                document.getElementById(typingId)?.remove();
                chatBody.innerHTML += `
                    <div class="chat-message bot">
                        <div class="message-content text-danger">
                            ❌ Không thể kết nối. Vui lòng thử lại sau.
                        </div>
                    </div>`;
                console.error('Chat error:', error);
            }

            chatBody.scrollTop = chatBody.scrollHeight;
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function formatResponse(text) {
            return text
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                .replace(/\n/g, '<br>');
        }
    </script>
</body>
</html>