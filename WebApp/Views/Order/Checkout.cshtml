@model Application.DTOs.Orders.CheckoutDto

@{
    ViewData["Title"] = "Thanh toán";
    var cartItems = ViewBag.CartItems as List<Application.DTOs.Orders.CartItemDto>;
    var cartTotal = ViewBag.CartTotal as decimal? ?? 0;
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Trang ch?</a></li>
            <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index" class="text-decoration-none">Gi? hŕng</a></li>
            <li class="breadcrumb-item active">Thanh toán</li>
        </ol>
    </nav>

    <!-- Progress Steps -->
    <div class="d-flex justify-content-center mb-5">
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center">
                <span class="badge rounded-circle bg-success p-2 me-2" style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;">
                    <i class="fa-solid fa-check"></i>
                </span>
                <span class="text-muted">Gi? hŕng</span>
            </div>
            <div style="width:40px;height:2px;background:#198754;"></div>
            <div class="d-flex align-items-center">
                <span class="badge rounded-circle bg-primary p-2 me-2" style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;">2</span>
                <span class="fw-bold text-primary">Thanh toán</span>
            </div>
            <div style="width:40px;height:2px;background:#dee2e6;"></div>
            <div class="d-flex align-items-center">
                <span class="badge rounded-circle bg-secondary p-2 me-2" style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;">3</span>
                <span class="text-muted">Hoŕn t?t</span>
            </div>
        </div>
    </div>

    <!-- Validation Errors -->
    @if (!ViewData.ModelState.IsValid)
    {
        var errors = ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage).Where(e => !string.IsNullOrEmpty(e));
        if (errors.Any())
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fa-solid fa-circle-exclamation me-2"></i>
                <strong>Vui lňng ki?m tra l?i:</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var error in errors)
                    {
                        <li>@error</li>
                    }
                </ul>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    }

    <form asp-action="Checkout" method="post">
        <div class="row g-4">
            <!-- C?t trái: Thông tin giao hŕng -->
            <div class="col-lg-7">
                <!-- Thông tin ngu?i nh?n -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0"><i class="fa-solid fa-user text-primary me-2"></i>Thông tin ngu?i nh?n</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label fw-semibold">
                                    H? vŕ tęn <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
                                    <input asp-for="FullName" class="form-control" placeholder="Nguy?n Van A" />
                                </div>
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label fw-semibold">
                                    S? di?n tho?i <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="0912 345 678" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Email" class="form-label fw-semibold">
                                    Email <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                                    <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Đ?a ch? giao hŕng -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0"><i class="fa-solid fa-location-dot text-danger me-2"></i>Đ?a ch? giao hŕng</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label asp-for="ShippingAddress" class="form-label fw-semibold">
                                Đ?a ch? chi ti?t <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-map-pin"></i></span>
                                <textarea asp-for="ShippingAddress" class="form-control" rows="2" placeholder="S? nhŕ, du?ng, phu?ng/xă, qu?n/huy?n, t?nh/thŕnh ph?"></textarea>
                            </div>
                            <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Note" class="form-label fw-semibold">
                                Ghi chú don hŕng
                            </label>
                            <textarea asp-for="Note" class="form-control" rows="2" placeholder="Ví d?: Giao hŕng gi? hŕnh chính, g?i tru?c khi giao..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Phuong th?c thanh toán -->
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0"><i class="fa-solid fa-credit-card text-success me-2"></i>Phuong th?c thanh toán</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="form-check border rounded-3 p-3 mb-3 bg-light">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="COD" id="paymentCOD" checked>
                            <label class="form-check-label w-100 d-flex align-items-center" for="paymentCOD">
                                <i class="fa-solid fa-money-bill-wave fa-lg text-success me-3"></i>
                                <div>
                                    <strong>Thanh toán khi nh?n hŕng (COD)</strong>
                                    <br><small class="text-muted">Thanh toán b?ng ti?n m?t khi nh?n hŕng</small>
                                </div>
                            </label>
                        </div>

                        <div class="form-check border rounded-3 p-3 mb-3">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="MoMo" id="paymentMoMo">
                            <label class="form-check-label w-100 d-flex align-items-center" for="paymentMoMo">
                                <i class="fa-solid fa-wallet fa-lg text-danger me-3"></i>
                                <div>
                                    <strong>Ví MoMo</strong>
                                    <br><small class="text-muted">Chuy?n sang MoMo d? thanh toán online</small>
                                </div>
                            </label>
                        </div>

                        <div class="form-check border rounded-3 p-3">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="BankTransfer" id="paymentBank">
                            <label class="form-check-label w-100 d-flex align-items-center" for="paymentBank">
                                <i class="fa-solid fa-building-columns fa-lg text-primary me-3"></i>
                                <div>
                                    <strong>Chuy?n kho?n ngân hŕng</strong>
                                    <br><small class="text-muted">Chuy?n kho?n qua tŕi kho?n ngân hŕng</small>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- C?t ph?i: Tóm t?t don hŕng -->
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fa-solid fa-receipt me-2"></i>Đon hŕng c?a b?n</h5>
                    </div>
                    <div class="card-body p-0">
                        <!-- Danh sách s?n ph?m -->
                        <div class="p-3" style="max-height: 350px; overflow-y: auto;">
                            @if (cartItems != null)
                            {
                                @foreach (var item in cartItems)
                                {
                                    <div class="d-flex gap-3 mb-3 pb-3 border-bottom">
                                        <div class="position-relative flex-shrink-0">
                                            <img src="@(item.ImageUrl ?? "https://via.placeholder.com/60")"
                                                 class="rounded border" style="width:60px;height:60px;object-fit:contain;" alt="@item.ProductName">
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" style="font-size:0.65rem;">
                                                x@item.Quantity
                                            </span>
                                        </div>
                                        <div class="flex-grow-1">
                                            <p class="mb-1 fw-semibold small text-truncate" style="max-width:200px;" title="@item.ProductName">
                                                @item.ProductName
                                            </p>
                                            <small class="text-muted">@item.Price.ToString("#,##0")? × @item.Quantity</small>
                                        </div>
                                        <div class="text-end flex-shrink-0">
                                            <span class="fw-bold text-danger">@item.Total.ToString("#,##0")?</span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <!-- T?ng ti?n -->
                        <div class="p-3 bg-light border-top">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">T?m tính:</span>
                                <span>@cartTotal.ToString("#,##0")?</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Phí v?n chuy?n:</span>
                                <span class="text-success fw-semibold">Mi?n phí</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between">
                                <strong class="fs-5">T?ng c?ng:</strong>
                                <strong class="fs-4 text-danger">@cartTotal.ToString("#,##0")?</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Nút d?t hŕng -->
                    <div class="card-footer bg-white p-3">
                        <button type="submit" class="btn btn-success btn-lg w-100 py-3 fw-bold">
                            <i class="fa-solid fa-lock me-2"></i>Đ?T HŔNG
                        </button>
                        <div class="text-center mt-2">
                            <small class="text-muted">
                                <i class="fa-solid fa-shield-halved text-success"></i>
                                Thông tin c?a b?n du?c b?o m?t
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Quay l?i gi? hŕng -->
                <div class="text-center mt-3">
                    <a asp-controller="Cart" asp-action="Index" class="text-decoration-none">
                        <i class="fa-solid fa-arrow-left me-1"></i> Quay l?i gi? hŕng
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
