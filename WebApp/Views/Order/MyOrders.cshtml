@model List<Application.DTOs.Orders.OrderDto>

@{
    ViewData["Title"] = "Ðon hàng c?a tôi";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fa-solid fa-box text-primary me-2"></i>Ðon hàng c?a tôi</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
            <i class="fa-solid fa-arrow-left me-1"></i> Ti?p t?c mua s?m
        </a>
    </div>

    <!-- Notifications -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle" style="width:100px;height:100px;">
                    <i class="fa-solid fa-box-open fa-3x text-muted"></i>
                </div>
            </div>
            <h4 class="text-muted">B?n chua có don hàng nào</h4>
            <p class="text-muted">Hãy khám phá các s?n ph?m tuy?t v?i c?a chúng tôi!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                <i class="fa-solid fa-shopping-bag me-2"></i>Mua s?m ngay
            </a>
        </div>
    }
    else
    {
        <!-- Desktop: Table view -->
        <div class="card shadow-sm border-0 d-none d-md-block">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã don</th>
                            <th>Ngày d?t</th>
                            <th>S?n ph?m</th>
                            <th>T?ng ti?n</th>
                            <th>Thanh toán</th>
                            <th>Tr?ng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@order.Id" class="fw-bold text-decoration-none">
                                        #@order.Id
                                    </a>
                                </td>
                                <td>
                                    <span>@order.OrderDate.ToString("dd/MM/yyyy")</span>
                                    <br><small class="text-muted">@order.OrderDate.ToString("HH:mm")</small>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @{
                                            var firstItem = order.Items.FirstOrDefault();
                                        }
                                        @if (firstItem != null)
                                        {
                                            <img src="@(firstItem.ImageUrl ?? "https://via.placeholder.com/40")"
                                                 class="rounded border me-2" style="width:40px;height:40px;object-fit:contain;">
                                            <div>
                                                <small class="fw-semibold text-truncate d-block" style="max-width:180px;">@firstItem.ProductName</small>
                                                @if (order.Items.Count > 1)
                                                {
                                                    <small class="text-muted">và @(order.Items.Count - 1) s?n ph?m khác</small>
                                                }
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold text-danger">@order.TotalAmount.ToString("#,##0")?</span>
                                </td>
                                <td>
                                    <small>@order.PaymentMethodDisplay</small>
                                </td>
                                <td>
                                    <span class="badge @order.StatusBadgeClass rounded-pill px-3">@order.StatusDisplay</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-primary" title="Xem chi ti?t">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        @if (order.Status == "Pending")
                                        {
                                            <form asp-action="Cancel" asp-route-id="@order.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('B?n có ch?c mu?n h?y don hàng #@order.Id?')">
                                                <button type="submit" class="btn btn-outline-danger" title="H?y don">
                                                    <i class="fa-solid fa-xmark"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Mobile: Card view -->
        <div class="d-md-none">
            @foreach (var order in Model)
            {
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <a asp-action="Details" asp-route-id="@order.Id" class="fw-bold text-decoration-none fs-6">#@order.Id</a>
                                <br><small class="text-muted">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <span class="badge @order.StatusBadgeClass rounded-pill">@order.StatusDisplay</span>
                        </div>

                        <div class="d-flex align-items-center mb-3">
                            @{
                                var mobileFirst = order.Items.FirstOrDefault();
                            }
                            @if (mobileFirst != null)
                            {
                                <img src="@(mobileFirst.ImageUrl ?? "https://via.placeholder.com/40")"
                                     class="rounded border me-2" style="width:40px;height:40px;object-fit:contain;">
                                <div>
                                    <small class="fw-semibold">@mobileFirst.ProductName</small>
                                    @if (order.Items.Count > 1)
                                    {
                                        <br><small class="text-muted">và @(order.Items.Count - 1) s?n ph?m khác</small>
                                    }
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <strong class="text-danger">@order.TotalAmount.ToString("#,##0")?</strong>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="fa-solid fa-eye me-1"></i>Chi ti?t
                                </a>
                                @if (order.Status == "Pending")
                                {
                                    <form asp-action="Cancel" asp-route-id="@order.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('B?n có ch?c mu?n h?y don hàng #@order.Id?')">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fa-solid fa-xmark me-1"></i>H?y
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Summary -->
        <div class="text-muted text-center mt-3">
            <small>T?ng c?ng <strong>@Model.Count</strong> don hàng</small>
        </div>
    }
</div>
