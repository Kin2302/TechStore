<div class="container py-5">
    <!-- Progress Steps -->
    <div class="d-flex justify-content-center mb-5">
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center">
                <span class="badge rounded-circle bg-success p-2 me-2" style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;">
                    <i class="fa-solid fa-check"></i>
                </span>
                <span class="text-muted">Gi? hÁng</span>
            </div>
            <div style="width:40px;height:2px;background:#198754;"></div>
            <div class="d-flex align-items-center">
                <span class="badge rounded-circle bg-success p-2 me-2" style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;">
                    <i class="fa-solid fa-check"></i>
                </span>
                <span class="text-muted">Thanh toÃn</span>
            </div>
            <div style="width:40px;height:2px;background:#198754;"></div>
            <div class="d-flex align-items-center">
                <span class="badge rounded-circle bg-success p-2 me-2" style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;">
                    <i class="fa-solid fa-check"></i>
                </span>
                <span class="fw-bold text-success">HoÁn t?t</span>
            </div>
        </div>
    </div>

    <!-- Success Message -->
    <div class="text-center mb-5">
        <div class="mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 rounded-circle" style="width:100px;height:100px;">
                <i class="fa-solid fa-circle-check fa-3x text-success"></i>
            </div>
        </div>
        <h2 class="fw-bold text-success">Å?t hÁng thÁnh c¶ng!</h2>
        <p class="text-muted fs-5">C?m on b?n dÐ mua hÁng t?i TechStore</p>
        <span class="badge bg-primary fs-6 px-3 py-2">MÐ don hÁng: #@Model.Id</span>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Th¶ng tin don hÁng -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0"><i class="fa-solid fa-truck text-primary me-2"></i>Th¶ng tin giao hÁng</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted" style="width:140px;"><i class="fa-solid fa-user me-2"></i>Ngu?i nh?n:</td>
                                <td class="fw-semibold">@Model.FullName</td>
                            </tr>
                            <tr>
                                <td class="text-muted"><i class="fa-solid fa-phone me-2"></i>Åi?n tho?i:</td>
                                <td class="fw-semibold">@Model.PhoneNumber</td>
                            </tr>
                            <tr>
                                <td class="text-muted"><i class="fa-solid fa-envelope me-2"></i>Email:</td>
                                <td class="fw-semibold">@Model.Email</td>
                            </tr>
                            <tr>
                                <td class="text-muted"><i class="fa-solid fa-location-dot me-2"></i>Å?a ch?:</td>
                                <td class="fw-semibold">@Model.ShippingAddress</td>
                            </tr>
                            @if (!string.IsNullOrEmpty(Model.Note))
                            {
                                <tr>
                                    <td class="text-muted"><i class="fa-solid fa-note-sticky me-2"></i>Ghi chº:</td>
                                    <td>@Model.Note</td>
                                </tr>
                            }
                            <tr>
                                <td class="text-muted"><i class="fa-solid fa-credit-card me-2"></i>Thanh toÃn:</td>
                                <td><span class="badge bg-info">@Model.PaymentMethodDisplay</span></td>
                            </tr>
                            <tr>
                                <td class="text-muted"><i class="fa-solid fa-clock me-2"></i>Tr?ng thÃi:</td>
                                <td><span class="badge @Model.StatusBadgeClass">@Model.StatusDisplay</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Chi ti?t s?n ph?m -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0"><i class="fa-solid fa-box text-warning me-2"></i>Chi ti?t s?n ph?m</h5>
                </div>
                <div class="card-body p-0">
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex gap-3 p-3 border-bottom align-items-center">
                            <img src="@(item.ImageUrl ?? "https://via.placeholder.com/50")"
                                 class="rounded border" style="width:50px;height:50px;object-fit:contain;">
                            <div class="flex-grow-1">
                                <p class="mb-0 fw-semibold small">@item.ProductName</p>
                                <small class="text-muted">@item.Price.ToString("#,##0")? æ @item.Quantity</small>
                            </div>
                            <span class="fw-bold text-danger">@item.Total.ToString("#,##0")?</span>
                        </div>
                    }
                    <div class="p-3 bg-light">
                        <div class="d-flex justify-content-between">
                            <strong class="fs-5">T?ng c?ng:</strong>
                            <strong class="fs-4 text-danger">@Model.TotalAmount.ToString("#,##0")?</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="text-center mt-5">
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Order" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-lg px-4">
                <i class="fa-solid fa-eye me-2"></i>Xem chi ti?t don hÁng
            </a>
            <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-secondary btn-lg px-4">
                <i class="fa-solid fa-list me-2"></i>Åon hÁng c?a t¶i
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4">
                <i class="fa-solid fa-house me-2"></i>V? trang ch?
            </a>
        </div>
    </div>
</div>
