@model List<Application.DTOs.CartItemDto>

@{
    ViewData["Title"] = "Giỏ hàng";
    var total = Model?.Sum(x => x.Total) ?? 0;
}

<div class="container py-4">
    <h2 class="mb-4">
        <i class="fa-solid fa-cart-shopping text-primary"></i> Giỏ hàng của bạn
    </h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-cart-arrow-down fa-5x text-muted mb-4"></i>
            <h4>Giỏ hàng trống</h4>
            <p class="text-muted">Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fa-solid fa-arrow-left"></i> Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Danh sách sản phẩm -->
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 100px;">Ảnh</th>
                                    <th>Sản phẩm</th>
                                    <th style="width: 120px;">Đơn giá</th>
                                    <th style="width: 130px;">Số lượng</th>
                                    <th style="width: 120px;">Thành tiền</th>
                                    <th style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr data-product-id="@item.ProductId">
                                        <td>
                                            <img src="@(item.ImageUrl ?? "https://via.placeholder.com/80")" 
                                                 class="img-thumbnail" style="width: 80px; height: 80px; object-fit: contain;">
                                        </td>
                                        <td class="align-middle">
                                            <a asp-controller="Home" asp-action="Detail" asp-route-id="@item.ProductId" 
                                               class="text-decoration-none fw-semibold">
                                                @item.ProductName
                                            </a>
                                        </td>
                                        <td class="align-middle text-danger fw-bold">
                                            @item.Price.ToString("#,##0")₫
                                        </td>
                                        <td class="align-middle">
                                            <div class="input-group input-group-sm" style="width: 110px;">
                                                <button class="btn btn-outline-secondary btn-decrease" type="button">−</button>
                                                <input type="number" class="form-control text-center quantity-input" 
                                                       value="@item.Quantity" min="1" max="99">
                                                <button class="btn btn-outline-secondary btn-increase" type="button">+</button>
                                            </div>
                                        </td>
                                        <td class="align-middle text-danger fw-bold item-total">
                                            @item.Total.ToString("#,##0")₫
                                        </td>
                                        <td class="align-middle">
                                            <button class="btn btn-sm btn-outline-danger btn-remove" title="Xóa">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                        <i class="fa-solid fa-arrow-left"></i> Tiếp tục mua sắm
                    </a>
                    <form asp-action="ClearCart" method="post">
                        <button type="submit" class="btn btn-outline-danger" 
                                onclick="return confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng?')">
                            <i class="fa-solid fa-trash"></i> Xóa giỏ hàng
                        </button>
                    </form>
                </div>
            </div>

            <!-- Tổng tiền -->
            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fa-solid fa-receipt"></i> Tóm tắt đơn hàng</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <span id="subtotal">@total.ToString("#,##0")₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Phí vận chuyển:</span>
                            <span class="text-success">Miễn phí</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Tổng cộng:</strong>
                            <strong class="text-danger fs-4" id="grandTotal">@total.ToString("#,##0")₫</strong>
                        </div>
                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-success btn-lg w-100">
                            <i class="fa-solid fa-credit-card"></i> Tiến hành đặt hàng
                        </a>
                    </div>
                </div>

                <!-- Mã giảm giá (tùy chọn) -->
                <div class="card shadow-sm mt-3">
                    <div class="card-body">
                        <h6><i class="fa-solid fa-ticket"></i> Mã giảm giá</h6>
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Nhập mã giảm giá">
                            <button class="btn btn-outline-primary">Áp dụng</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tăng số lượng
            $('.btn-increase').click(function() {
                var input = $(this).siblings('.quantity-input');
                var newVal = parseInt(input.val()) + 1;
                input.val(newVal);
                updateQuantity($(this).closest('tr'));
            });

            // Giảm số lượng
            $('.btn-decrease').click(function() {
                var input = $(this).siblings('.quantity-input');
                var newVal = parseInt(input.val()) - 1;
                if (newVal >= 1) {
                    input.val(newVal);
                    updateQuantity($(this).closest('tr'));
                }
            });

            // Thay đổi trực tiếp
            $('.quantity-input').change(function() {
                if (parseInt($(this).val()) < 1) $(this).val(1);
                updateQuantity($(this).closest('tr'));
            });

            // Xóa sản phẩm
            $('.btn-remove').click(function() {
                var row = $(this).closest('tr');
                var productId = row.data('product-id');
                
                $.post('@Url.Action("RemoveFromCart", "Cart")', { productId: productId }, function(response) {
                    if (response.success) {
                        row.fadeOut(300, function() {
                            $(this).remove();
                            updateCartCount(response.cartCount);
                            if ($('tbody tr').length === 0) {
                                location.reload();
                            }
                        });
                    }
                });
            });

            function updateQuantity(row) {
                var productId = row.data('product-id');
                var quantity = row.find('.quantity-input').val();
                
                $.post('@Url.Action("UpdateQuantity", "Cart")', 
                    { productId: productId, quantity: quantity }, 
                    function(response) {
                        if (response.success) {
                            // Cập nhật thành tiền của dòng
                            var price = parseFloat(row.find('td:eq(2)').text().replace(/[^\d]/g, ''));
                            var itemTotal = price * quantity;
                            row.find('.item-total').text(formatCurrency(itemTotal) + '₫');
                            
                            // Cập nhật tổng
                            updateTotals();
                            updateCartCount(response.cartCount);
                        }
                    }
                );
            }

            function updateTotals() {
                var total = 0;
                $('tbody tr').each(function() {
                    var itemTotal = parseFloat($(this).find('.item-total').text().replace(/[^\d]/g, ''));
                    total += itemTotal;
                });
                $('#subtotal').text(formatCurrency(total) + '₫');
                $('#grandTotal').text(formatCurrency(total) + '₫');
            }

            function updateCartCount(count) {
                $('#cartCount').text(count);
            }

            function formatCurrency(num) {
                return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
            }
        });
    </script>
}