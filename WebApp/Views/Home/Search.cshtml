@model List<Application.DTOs.Catalog.ProductDto>

@{
    ViewData["Title"] = "Tìm kiếm";
    var keyword    = ViewBag.Keyword as string;
    var categoryId = ViewBag.CategoryId as int?;
    var minPrice   = ViewBag.MinPrice as decimal?;
    var maxPrice   = ViewBag.MaxPrice as decimal?;
    var sortBy     = ViewBag.SortBy as string ?? "name";
    var categories = ViewBag.Categories as IEnumerable<TechStore.Domain.Entities.Category>
                     ?? Enumerable.Empty<TechStore.Domain.Entities.Category>();

    var sortOptions = new[]
    {
        new { Value = "name",       Label = "Tên A-Z" },
        new { Value = "price_asc",  Label = "Giá tăng dần" },
        new { Value = "price_desc", Label = "Giá giảm dần" },
        new { Value = "newest",     Label = "Mới nhất" },
        new { Value = "popular",    Label = "Bán chạy" },
    };
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <i class="fa-solid fa-house"></i> Trang chủ
                </a>
            </li>
            <li class="breadcrumb-item active">Tìm kiếm</li>
        </ol>
    </nav>

    <!-- Search bar lớn -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <form asp-action="Search" method="get">
                <div class="row g-2">
                    <div class="col-md-8">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white"><i class="fa-solid fa-search text-muted"></i></span>
                            <input type="text" name="q" class="form-control border-start-0 ps-0"
                                   placeholder="Tìm kiếm linh kiện, bo mạch, cảm biến..."
                                   value="@keyword">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="fa-solid fa-search me-1"></i>Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4">
        <!-- Sidebar Filter -->
        <div class="col-lg-3">
            <form asp-action="Search" method="get" id="filterForm">
                <input type="hidden" name="q" value="@keyword" />

                <!-- Danh mục -->
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0"><i class="fa-solid fa-folder-tree text-warning me-2"></i>Danh mục</h6>
                    </div>
                    <div class="card-body p-3">
                        <div class="list-group list-group-flush">
                            <a asp-action="Search" asp-route-q="@keyword"
                               class="list-group-item list-group-item-action border-0 px-0 py-2 @(categoryId == null ? "fw-bold text-primary" : "")">
                                <i class="fa-solid fa-th-large me-2"></i>Tất cả danh mục
                            </a>
                            @foreach (var cat in categories)
                            {
                                <a asp-action="Search" asp-route-q="@keyword" asp-route-categoryId="@cat.Id"
                                   asp-route-minPrice="@minPrice" asp-route-maxPrice="@maxPrice"
                                   asp-route-sortBy="@sortBy"
                                   class="list-group-item list-group-item-action border-0 px-0 py-2 @(categoryId == cat.Id ? "fw-bold text-primary" : "")">
                                    <i class="fa-solid fa-chevron-right me-2 small"></i>@cat.Name
                                </a>
                            }
                        </div>
                    </div>
                </div>

                <!-- Khoảng giá -->
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0"><i class="fa-solid fa-money-bill text-success me-2"></i>Khoảng giá</h6>
                    </div>
                    <div class="card-body p-3">
                        @if (categoryId.HasValue)
                        {
                            <input type="hidden" name="categoryId" value="@categoryId" />
                        }
                        <input type="hidden" name="sortBy" value="@sortBy" />
                        <div class="mb-2">
                            <label class="form-label small text-muted">Giá từ (₫)</label>
                            <input type="number" name="minPrice" class="form-control form-control-sm"
                                   placeholder="0" min="0" value="@minPrice">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">Giá đến (₫)</label>
                            <input type="number" name="maxPrice" class="form-control form-control-sm"
                                   placeholder="999,999,999" min="0" value="@maxPrice">
                        </div>

                        <!-- Giá nhanh -->
                        <div class="d-flex flex-wrap gap-1 mb-3">
                            @{
                                var quickPrices = new[]
                                {
                                    new { Label = "< 50k",  Min = (decimal?)null, Max = (decimal?)50000 },
                                    new { Label = "< 200k", Min = (decimal?)null, Max = (decimal?)200000 },
                                    new { Label = "< 500k", Min = (decimal?)null, Max = (decimal?)500000 },
                                    new { Label = "< 1M",   Min = (decimal?)null, Max = (decimal?)1000000 },
                                };
                            }
                            @foreach (var qp in quickPrices)
                            {
                                var isActive = maxPrice == qp.Max && minPrice == qp.Min;
                                <a asp-action="Search"
                                   asp-route-q="@keyword"
                                   asp-route-categoryId="@categoryId"
                                   asp-route-maxPrice="@qp.Max"
                                   asp-route-sortBy="@sortBy"
                                   class="badge @(isActive ? "bg-primary" : "bg-light text-dark") text-decoration-none">
                                    @qp.Label
                                </a>
                            }
                        </div>

                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="fa-solid fa-filter me-1"></i>Áp dụng
                        </button>
                        @if (minPrice.HasValue || maxPrice.HasValue || categoryId.HasValue)
                        {
                            <a asp-action="Search" asp-route-q="@keyword"
                               class="btn btn-outline-secondary btn-sm w-100 mt-2">
                                <i class="fa-solid fa-rotate-left me-1"></i>Xóa bộ lọc
                            </a>
                        }
                    </div>
                </div>
            </form>
        </div>

        <!-- Results -->
        <div class="col-lg-9">
            <!-- Header kết quả -->
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <div>
                    @if (!string.IsNullOrEmpty(keyword))
                    {
                        <h5 class="mb-0">
                            Kết quả cho: <span class="text-primary">"@keyword"</span>
                            <span class="badge bg-secondary ms-2">@Model.Count sản phẩm</span>
                        </h5>
                    }
                    else
                    {
                        <h5 class="mb-0">
                            Tất cả sản phẩm
                            <span class="badge bg-secondary ms-2">@Model.Count sản phẩm</span>
                        </h5>
                    }
                    @if (categoryId.HasValue)
                    {
                        var selectedCat = categories.FirstOrDefault(c => c.Id == categoryId);
                        if (selectedCat != null)
                        {
                            <small class="text-muted">
                                Danh mục: <span class="badge bg-warning text-dark">@selectedCat.Name</span>
                            </small>
                        }
                    }
                </div>

                <!-- Sort -->
                <div class="d-flex align-items-center gap-2">
                    <small class="text-muted text-nowrap">Sắp xếp:</small>
                    <select class="form-select form-select-sm" style="width: auto;"
                            onchange="applySortBy(this.value)">
                        @foreach (var opt in sortOptions)
                        {
                            <option value="@opt.Value" selected="@(sortBy == opt.Value)">@opt.Label</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Product Grid -->
            @if (!Model.Any())
            {
                <div class="card shadow-sm border-0">
                    <div class="card-body text-center py-5">
                        <i class="fa-solid fa-box-open fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">Không tìm thấy sản phẩm nào</h5>
                        @if (!string.IsNullOrEmpty(keyword))
                        {
                            <p class="text-muted">Thử tìm với từ khóa khác hoặc bỏ bộ lọc</p>
                        }
                        <a asp-action="Search" class="btn btn-outline-primary mt-2">
                            <i class="fa-solid fa-rotate-left me-1"></i>Xóa bộ lọc
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var item in Model)
                    {
                        var avatar = item.ImageUrl ?? "https://via.placeholder.com/300x200?text=No+Image";
                        <div class="col-xl-4 col-md-6">
                            <div class="card h-100 border-0 shadow-sm product-card">
                                @if (item.Stock <= 0)
                                {
                                    <span class="badge bg-secondary position-absolute top-0 start-0 m-2">Hết hàng</span>
                                }
                                else if (item.Stock <= 5)
                                {
                                    <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2">Sắp hết</span>
                                }

                                <a asp-action="Detail" asp-route-id="@item.Id">
                                    <img src="@avatar" class="card-img-top"
                                         style="height:180px;object-fit:contain;padding:12px;"
                                         alt="@item.Name">
                                </a>

                                <div class="card-body d-flex flex-column p-3">
                                    <small class="text-muted text-uppercase mb-1" style="font-size:0.7rem;">
                                        @item.CategoryName
                                    </small>
                                    <h6 class="card-title mb-2">
                                        <a asp-action="Detail" asp-route-id="@item.Id"
                                           class="text-decoration-none text-dark">@item.Name</a>
                                    </h6>
                                    @if (!string.IsNullOrEmpty(item.BrandName))
                                    {
                                        <small class="text-muted mb-2">
                                            <i class="fa-solid fa-building me-1"></i>@item.BrandName
                                        </small>
                                    }
                                    <div class="mt-auto">
                                        <h5 class="text-danger fw-bold mb-1">
                                            @item.Price.ToString("#,##0")₫
                                        </h5>
                                        <small class="text-muted d-block mb-2">
                                            <i class="fa-solid fa-box me-1"></i>Kho: @item.Stock
                                        </small>
                                        <button class="btn btn-primary btn-sm w-100 add-cart-btn"
                                                data-product-id="@item.Id"
                                                @(item.Stock <= 0 ? "disabled" : "")>
                                            <i class="fa-solid fa-cart-plus me-1"></i>Thêm vào giỏ
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Sort by thay đổi → submit form
        function applySortBy(value) {
            var url = new URL(window.location.href);
            url.searchParams.set('sortBy', value);
            window.location.href = url.toString();
        }

        // Add to cart (giống Index)
        $(document).ready(function () {
            $('.add-cart-btn').click(function (e) {
                e.preventDefault();
                var btn = $(this);
                var productId = btn.data('product-id');

                $.ajax({
                    url: '@Url.Action("AddToCart", "Cart")',
                    type: 'POST',
                    data: { productId: productId },
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function (response) {
                        if (response.success) {
                            $('#cartCount').text(response.cartCount);
                            btn.html('<i class="fa-solid fa-check"></i> Đã thêm');
                            setTimeout(function () {
                                btn.html('<i class="fa-solid fa-cart-plus me-1"></i>Thêm vào giỏ');
                            }, 1500);
                        }
                    }
                });
            });
        });
    </script>
}