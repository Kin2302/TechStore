@using TechStore.Domain.Entities
@model Application.DTOs.Catalog.ProductDetailDto

@{
    ViewData["Title"] = Model.Name;
    var mainImage = Model.ImageUrl ?? "https://via.placeholder.com/500x400?text=No+Image";
    var activeTab = Context.Request.Query["tab"].ToString();
    var isReviewTab = string.Equals(activeTab, "reviews", StringComparison.OrdinalIgnoreCase);
}

<div class="container py-4">
    @if (TempData["ReviewSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["ReviewSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ReviewError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ReviewError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">@Model.CategoryName</a></li>
            <li class="breadcrumb-item active text-truncate" style="max-width: 200px;">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- IMAGE GALLERY -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <div class="main-image-wrapper mb-3 text-center bg-light rounded-3 p-3">
                        <img src="@mainImage" id="mainImage" class="img-fluid" alt="@Model.Name"
                             style="max-height: 350px; object-fit: contain;">
                    </div>

                    @if (Model.Images?.Any() == true)
                    {
                        <div class="d-flex gap-2 justify-content-center flex-wrap">
                            @foreach (var img in Model.Images)
                            {
                                <img src="@img.ImageUrl"
                                     class="img-thumbnail thumbnail-item @(img.IsMain ? "border-primary border-2" : "")"
                                     style="width: 60px; height: 60px; object-fit: cover; cursor: pointer;"
                                     onclick="changeMainImage(this.src)">
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- PRODUCT INFO -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex gap-2 mb-2">
                        @if (!string.IsNullOrEmpty(Model.BrandName))
                        {
                            <span class="badge bg-primary">@Model.BrandName</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.CategoryName))
                        {
                            <span class="badge bg-secondary">@Model.CategoryName</span>
                        }
                    </div>

                    <h2 class="fw-bold mb-3">@Model.Name</h2>

                    <div class="d-flex align-items-center gap-3 mb-3 text-muted">
                        <span><i class="fa-solid fa-barcode"></i> Mã: <strong>@Model.Code</strong></span>
                        <span class="vr"></span>

                        @if (Model.ReviewCount > 0)
                        {
                            <span class="text-warning">
                                <i class="fa-solid fa-star"></i> @Model.AverageRating (@Model.ReviewCount đánh giá)
                            </span>
                            <span class="vr"></span>
                        }

                        @if (Model.Stock > 10)
                        {
                            <span class="text-success"><i class="fa-solid fa-circle-check"></i> Còn hàng (@Model.Stock)</span>
                        }
                        else if (Model.Stock > 0)
                        {
                            <span class="text-warning"><i class="fa-solid fa-triangle-exclamation"></i> Chỉ còn @Model.Stock</span>
                        }
                        else
                        {
                            <span class="text-danger"><i class="fa-solid fa-circle-xmark"></i> Hết hàng</span>
                        }
                    </div>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <h2 class="text-danger fw-bold mb-0">
                            @Model.Price.ToString("#,##0")₫
                        </h2>
                    </div>

                    <p class="text-muted mb-4">@Model.ShortDescription</p>

                    <div class="row g-3 mb-4">
                        <div class="col-auto">
                            <label class="form-label fw-semibold">Số lượng</label>
                            <div class="input-group" style="width: 130px;">
                                <button class="btn btn-outline-secondary" type="button" onclick="decreaseQty()">−</button>
                                <input type="number" class="form-control text-center" id="quantity" value="1" min="1" max="@Model.Stock">
                                <button class="btn btn-outline-secondary" type="button" onclick="increaseQty()">+</button>
                            </div>
                        </div>
                        <div class="col">
                            <label class="form-label">&nbsp;</label>
                            <div class="d-flex gap-2">
                                <button class="btn btn-primary btn-lg flex-grow-1 add-cart-btn"
                                        data-product-id="@Model.Id"
                                        @(Model.Stock == 0 ? "disabled" : "")>
                                    <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ
                                </button>
                                <button class="btn btn-outline-danger btn-lg wishlist-btn" title="Yêu thích" data-product-id="@Model.Id">
                                    <i class="fa-regular fa-heart"></i>
                                </button>
                                <button class="btn btn-outline-secondary btn-lg compare-btn" title="So sánh" data-product-id="@Model.Id">
                                    <i class="fa-solid fa-code-compare"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="border-top pt-3">
                        <div class="row g-2 text-muted small">
                            <div class="col-6">
                                <i class="fa-solid fa-truck text-primary"></i> Giao hàng: 2-3 ngày
                            </div>
                            <div class="col-6">
                                <i class="fa-solid fa-shield text-success"></i> Bảo hành: 6 tháng
                            </div>
                            <div class="col-6">
                                <i class="fa-solid fa-rotate-left text-warning"></i> Đổi trả: 7 ngày
                            </div>
                            <div class="col-6">
                                <i class="fa-solid fa-headset text-info"></i> Hỗ trợ: 24/7
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SPECIFICATIONS & DESCRIPTION TABS -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <ul class="nav nav-tabs nav-fill" id="productTabs" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link @(isReviewTab ? "" : "active") py-3" data-bs-toggle="tab" data-bs-target="#specs">
                                <i class="fa-solid fa-microchip"></i> Thông số kỹ thuật
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link py-3" data-bs-toggle="tab" data-bs-target="#desc">
                                <i class="fa-solid fa-file-lines"></i> Mô tả chi tiết
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(isReviewTab ? "active" : "") py-3" data-bs-toggle="tab" data-bs-target="#reviews">
                                <i class="fa-solid fa-star"></i> Đánh giá (@Model.ReviewCount)
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content p-4">
                        <div class="tab-pane fade @(isReviewTab ? "" : "show active")" id="specs">
                            @if (Model.Specifications?.Any() == true)
                            {
                                <table class="table table-striped table-hover mb-0">
                                    <tbody>
                                        @foreach (var spec in Model.Specifications)
                                        {
                                            <tr>
                                                <th class="bg-light" style="width: 35%;">@spec.Name</th>
                                                <td>@spec.Value</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fa-solid fa-info-circle"></i> Chưa có thông số kỹ thuật.</p>
                            }
                        </div>

                        <div class="tab-pane fade" id="desc">
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                @Html.Raw(Model.Description)
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fa-solid fa-info-circle"></i> Chưa có mô tả chi tiết.</p>
                            }
                        </div>

                        <div class="tab-pane fade @(isReviewTab ? "show active" : "")" id="reviews">
                            @if (Model.ReviewCount > 0)
                            {
                                <div class="mb-4 p-3 bg-light rounded-3">
                                    <h5 class="mb-1">Đánh giá trung bình: <span class="text-warning">@Model.AverageRating</span>/5</h5>
                                    <small class="text-muted">Dựa trên @Model.ReviewCount đánh giá</small>
                                </div>

                                @foreach (var review in Model.Reviews)
                                {
                                    <div class="border rounded-3 p-3 mb-3">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <strong>@review.UserName</strong>
                                            <small class="text-muted">@review.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
                                        </div>
                                        <div class="text-warning mb-2">
                                            @for (var i = 1; i <= 5; i++)
                                            {
                                                if (i <= review.Rating)
                                                {
                                                    <i class="fa-solid fa-star"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa-regular fa-star"></i>
                                                }
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(review.Comment))
                                        {
                                            <p class="mb-0">@review.Comment</p>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-3 text-muted">
                                    <i class="fa-regular fa-comment-dots fa-3x mb-3"></i>
                                    <p>Chưa có đánh giá nào cho sản phẩm này.</p>
                                </div>
                            }

                            <hr />

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <h5 class="mb-3"><i class="fa-solid fa-pen"></i> Viết đánh giá của bạn</h5>
                                <form asp-controller="Review" asp-action="Create" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ProductId" value="@Model.Id" />

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Điểm đánh giá</label>
                                        <select class="form-select" name="Rating" required>
                                            <option value="5">5 - Rất tốt</option>
                                            <option value="4">4 - Tốt</option>
                                            <option value="3">3 - Bình thường</option>
                                            <option value="2">2 - Chưa tốt</option>
                                            <option value="1">1 - Tệ</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Nhận xét</label>
                                        <textarea class="form-control" name="Comment" rows="3" placeholder="Chia sẻ trải nghiệm của bạn..."></textarea>
                                    </div>

                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa-solid fa-paper-plane"></i> Gửi đánh giá
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="alert alert-info mb-0">
                                    Vui lòng
                                    <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Context.Request.Path" class="fw-semibold">đăng nhập</a>
                                    để gửi đánh giá.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeMainImage(src) {
            document.getElementById('mainImage').src = src;
            document.querySelectorAll('.thumbnail-item').forEach(img => {
                img.classList.remove('border-primary', 'border-2');
                if (img.src === src) {
                    img.classList.add('border-primary', 'border-2');
                }
            });
        }

        function increaseQty() {
            const input = document.getElementById('quantity');
            const max = parseInt(input.max);
            if (parseInt(input.value) < max) {
                input.value = parseInt(input.value) + 1;
            }
        }

        function decreaseQty() {
            const input = document.getElementById('quantity');
            if (parseInt(input.value) > 1) {
                input.value = parseInt(input.value) - 1;
            }
        }

        $(document).ready(function() {
            $('.add-cart-btn').click(function(e) {
                e.preventDefault();
                var btn = $(this);
                var productId = btn.data('product-id');
                var quantity = parseInt($('#quantity').val());

                $.ajax({
                    url: '@Url.Action("AddToCart", "Cart")',
                    type: 'POST',
                    data: { productId: productId, quantity: quantity },
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function(response) {
                        if (response.success) {
                            $('#cartCount').text(response.cartCount);
                            btn.html('<i class="fa-solid fa-check"></i> Đã thêm');
                            setTimeout(function() {
                                btn.html('<i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ');
                            }, 1500);
                        }
                    },
                    error: function() {
                        alert('Có lỗi xảy ra!');
                    }
                });
            });

            $('.compare-btn').click(function (e) {
                e.preventDefault();
                var productId = $(this).data('product-id');

                $.ajax({
                    url: '@Url.Action("Add", "Compare")',
                    type: 'POST',
                    data: { productId: productId },
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function (response) {
                        alert(response.message);
                        if (response.success) {
                            $('#compareCount').text(response.compareCount);
                        }
                    }
                });
            });
        });
    </script>
}