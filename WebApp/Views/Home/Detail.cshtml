@using TechStore.Domain.Entities
@model Product

@{
    ViewData["Title"] = Model.Name;
    var mainImage = Model.Images?.FirstOrDefault(x => x.IsMain)?.ImageUrl
        ?? Model.Images?.FirstOrDefault()?.ImageUrl
        ?? "https://via.placeholder.com/500x400?text=No+Image";
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">@Model.Category?.Name</a></li>
            <li class="breadcrumb-item active text-truncate" style="max-width: 200px;">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- IMAGE GALLERY -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <!-- Main Image -->
                    <div class="main-image-wrapper mb-3 text-center bg-light rounded-3 p-3">
                        <img src="@mainImage" id="mainImage" class="img-fluid" alt="@Model.Name" 
                             style="max-height: 350px; object-fit: contain;">
                    </div>
                    
                    <!-- Thumbnails -->
                    @if (Model.Images?.Any() == true)
                    {
                        <div class="d-flex gap-2 justify-content-center flex-wrap">
                            @foreach (var img in Model.Images)
                            {
                                <img src="@img.ImageUrl" 
                                     class="img-thumbnail thumbnail-item @(img.IsMain ? "border-primary border-2" : "")" 
                                     style="width: 60px; height: 60px; object-fit: cover; cursor: pointer;"
                                     onclick="changeMainImage(this.src)">
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- PRODUCT INFO -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <!-- Brand & Category -->
                    <div class="d-flex gap-2 mb-2">
                        @if (Model.Brand != null)
                        {
                            <span class="badge bg-primary">@Model.Brand.Name</span>
                        }
                        <span class="badge bg-secondary">@Model.Category?.Name</span>
                    </div>

                    <!-- Name -->
                    <h2 class="fw-bold mb-3">@Model.Name</h2>

                    <!-- Code & Stock -->
                    <div class="d-flex align-items-center gap-3 mb-3 text-muted">
                        <span><i class="fa-solid fa-barcode"></i> Mã: <strong>@Model.Code</strong></span>
                        <span class="vr"></span>
                        @if (Model.Stock > 10)
                        {
                            <span class="text-success"><i class="fa-solid fa-circle-check"></i> Còn hàng (@Model.Stock)</span>
                        }
                        else if (Model.Stock > 0)
                        {
                            <span class="text-warning"><i class="fa-solid fa-triangle-exclamation"></i> Chỉ còn @Model.Stock</span>
                        }
                        else
                        {
                            <span class="text-danger"><i class="fa-solid fa-circle-xmark"></i> Hết hàng</span>
                        }
                    </div>

                    <!-- Price -->
                    <div class="bg-light rounded-3 p-3 mb-4">
                        <h2 class="text-danger fw-bold mb-0">
                            @Model.Price.ToString("#,##0")₫
                        </h2>
                    </div>

                    <!-- Short Description -->
                    <p class="text-muted mb-4">@Model.ShortDescription</p>

                    <!-- Quantity & Add to Cart -->
                    <div class="row g-3 mb-4">
                        <div class="col-auto">
                            <label class="form-label fw-semibold">Số lượng</label>
                            <div class="input-group" style="width: 130px;">
                                <button class="btn btn-outline-secondary" type="button" onclick="decreaseQty()">−</button>
                                <input type="number" class="form-control text-center" id="quantity" value="1" min="1" max="@Model.Stock">
                                <button class="btn btn-outline-secondary" type="button" onclick="increaseQty()">+</button>
                            </div>
                        </div>
                        <div class="col">
                            <label class="form-label">&nbsp;</label>
                            <div class="d-flex gap-2">
                                <button class="btn btn-primary btn-lg flex-grow-1" @(Model.Stock == 0 ? "disabled" : "")>
                                    <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ
                                </button>
                                <button class="btn btn-outline-danger btn-lg" title="Yêu thích">
                                    <i class="fa-regular fa-heart"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Info -->
                    <div class="border-top pt-3">
                        <div class="row g-2 text-muted small">
                            <div class="col-6">
                                <i class="fa-solid fa-truck text-primary"></i> Giao hàng: 2-3 ngày
                            </div>
                            <div class="col-6">
                                <i class="fa-solid fa-shield text-success"></i> Bảo hành: 6 tháng
                            </div>
                            <div class="col-6">
                                <i class="fa-solid fa-rotate-left text-warning"></i> Đổi trả: 7 ngày
                            </div>
                            <div class="col-6">
                                <i class="fa-solid fa-headset text-info"></i> Hỗ trợ: 24/7
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SPECIFICATIONS & DESCRIPTION TABS -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <ul class="nav nav-tabs nav-fill" id="productTabs" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active py-3" data-bs-toggle="tab" data-bs-target="#specs">
                                <i class="fa-solid fa-microchip"></i> Thông số kỹ thuật
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link py-3" data-bs-toggle="tab" data-bs-target="#desc">
                                <i class="fa-solid fa-file-lines"></i> Mô tả chi tiết
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link py-3" data-bs-toggle="tab" data-bs-target="#reviews">
                                <i class="fa-solid fa-star"></i> Đánh giá (0)
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content p-4">
                        <!-- Specifications Tab -->
                        <div class="tab-pane fade show active" id="specs">
                            @if (Model.Specifications?.Any() == true)
                            {
                                <table class="table table-striped table-hover mb-0">
                                    <tbody>
                                        @foreach (var spec in Model.Specifications)
                                        {
                                            <tr>
                                                <th class="bg-light" style="width: 35%;">@spec.Name</th>
                                                <td>@spec.Value</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fa-solid fa-info-circle"></i> Chưa có thông số kỹ thuật.</p>
                            }
                        </div>

                        <!-- Description Tab -->
                        <div class="tab-pane fade" id="desc">
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                @Html.Raw(Model.Description)
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fa-solid fa-info-circle"></i> Chưa có mô tả chi tiết.</p>
                            }
                        </div>

                        <!-- Reviews Tab -->
                        <div class="tab-pane fade" id="reviews">
                            <div class="text-center py-5 text-muted">
                                <i class="fa-regular fa-comment-dots fa-3x mb-3"></i>
                                <p>Chưa có đánh giá nào cho sản phẩm này.</p>
                                <button class="btn btn-outline-primary">Viết đánh giá đầu tiên</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeMainImage(src) {
            document.getElementById('mainImage').src = src;
            // Update active thumbnail
            document.querySelectorAll('.thumbnail-item').forEach(img => {
                img.classList.remove('border-primary', 'border-2');
                if (img.src === src) {
                    img.classList.add('border-primary', 'border-2');
                }
            });
        }

        function increaseQty() {
            const input = document.getElementById('quantity');
            const max = parseInt(input.max);
            if (parseInt(input.value) < max) {
                input.value = parseInt(input.value) + 1;
            }
        }

        function decreaseQty() {
            const input = document.getElementById('quantity');
            if (parseInt(input.value) > 1) {
                input.value = parseInt(input.value) - 1;
            }
        }
    </script>
}