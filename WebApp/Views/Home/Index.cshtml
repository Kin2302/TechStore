@using TechStore.Domain.Entities
@model List<Application.DTOs.Catalog.ProductDto>

@{
    ViewData["Title"] = "Trang chủ";
}

<!-- HERO BANNER -->
<section class="hero-section mb-5">
    <div class="container">
        <div class="row align-items-center py-5 rounded-4" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);">
            <div class="col-lg-6 text-white p-5">
                <h1 class="display-4 fw-bold mb-3">
                    <i class="fa-solid fa-microchip text-warning"></i> TechStore
                </h1>
                <p class="lead mb-4">Nền tảng linh kiện điện tử thông minh dành cho dân điện tử & Sinh viên Việt Nam</p>
                <div class="d-flex gap-3">
                    <a href="#products" class="btn btn-warning btn-lg px-4">
                        <i class="fa-solid fa-bolt"></i> Khám phá ngay
                    </a>
                    <a href="#" class="btn btn-outline-light btn-lg px-4">
                        <i class="fa-solid fa-robot"></i> Hỏi AI tư vấn
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center d-none d-lg-block">
                <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=500" 
                     alt="Electronics" class="img-fluid rounded-3 shadow" style="max-height: 300px; object-fit: cover;">
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="features mb-5">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-3 col-6">
                <div class="p-3 bg-light rounded-3">
                    <i class="fa-solid fa-truck-fast fa-2x text-primary mb-2"></i>
                    <h6 class="mb-0">Giao hàng nhanh</h6>
                    <small class="text-muted">Toàn quốc 2-3 ngày</small>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="p-3 bg-light rounded-3">
                    <i class="fa-solid fa-shield-halved fa-2x text-success mb-2"></i>
                    <h6 class="mb-0">Bảo hành 6 tháng</h6>
                    <small class="text-muted">Đổi mới 1-1</small>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="p-3 bg-light rounded-3">
                    <i class="fa-solid fa-headset fa-2x text-warning mb-2"></i>
                    <h6 class="mb-0">Hỗ trợ 24/7</h6>
                    <small class="text-muted">Chat AI tư vấn</small>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="p-3 bg-light rounded-3">
                    <i class="fa-solid fa-percent fa-2x text-danger mb-2"></i>
                    <h6 class="mb-0">Giá sinh viên</h6>
                    <small class="text-muted">Giảm 10% có thẻ SV</small>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PRODUCT SECTION -->
<section id="products" class="mb-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0">
                <i class="fa-solid fa-fire text-danger"></i> Sản phẩm nổi bật
            </h3>
            <a href="#" class="btn btn-outline-primary btn-sm">Xem tất cả <i class="fa-solid fa-arrow-right"></i></a>
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    var avatar = item.ImageUrl ?? "https://via.placeholder.com/300x200?text=No+Image";

                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <div class="card product-card h-100">
                            @if (item.Stock < 10 && item.Stock > 0)
                            {
                                <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2 stock-badge">Sắp hết</span>
                            }
                            else if (item.Stock == 0)
                            {
                                <span class="badge bg-secondary position-absolute top-0 start-0 m-2 stock-badge">Hết hàng</span>
                            }

                            <div class="card-img-wrapper">
                                <a asp-action="Detail" asp-route-id="@item.Id">
                                    <img src="@avatar" class="card-img-top" alt="@item.Name">
                                </a>

                                <div class="quick-actions">
                                    <button class="btn btn-light btn-sm wishlist-btn" title="Yêu thích" data-product-id="@item.Id">
                                        <i class="fa-regular fa-heart"></i>
                                    </button>
                                    <button class="btn btn-light btn-sm compare-btn" title="So sánh" data-product-id="@item.Id">
                                        <i class="fa-solid fa-code-compare"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="card-body d-flex flex-column">
                                <small class="text-muted text-uppercase product-category">
                                    @item.CategoryName
                                </small>

                                <h6 class="card-title mt-1 mb-2 product-title">
                                    <a asp-action="Detail" asp-route-id="@item.Id" class="text-decoration-none">
                                        @item.Name
                                    </a>
                                </h6>

                                <div class="mt-auto">
                                    <h5 class="text-danger fw-bold mb-2">
                                        @item.Price.ToString("#,##0")₫
                                    </h5>

                                    <div class="d-flex align-items-center mb-3 stock-info">
                                        <i class="fa-solid fa-box me-1"></i>
                                        <small>Kho: @item.Stock</small>
                                    </div>

                                    <button class="btn btn-primary w-100 add-cart-btn" data-product-id="@item.Id" @(item.Stock == 0 ? "disabled" : "")>
                                        <i class="fa-solid fa-cart-plus me-1"></i> Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-info text-center py-5">
                        <i class="fa-solid fa-box-open fa-3x mb-3 text-muted"></i>
                        <h5>Chưa có sản phẩm nào</h5>
                        <p class="text-muted mb-0">Vui lòng quay lại sau hoặc liên hệ Admin để thêm sản phẩm mẫu.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Add to cart
            $('.add-cart-btn').click(function (e) {
                e.preventDefault();

                var btn = $(this);
                if (btn.hasClass('is-loading')) return;

                var productId = btn.data('product-id');
                var originalHtml = btn.html();

                btn.addClass('is-loading')
                   .prop('disabled', true)
                   .html('<span class="spinner-border spinner-border-sm me-2"></span>Đang thêm...');

                $.ajax({
                    url: '@Url.Action("AddToCart", "Cart")',
                    type: 'POST',
                    data: { productId: productId },
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function (response) {
                        if (response.success) {
                            var badge = $('#cartCount');
                            badge.text(response.cartCount).addClass('bump');
                            setTimeout(function () { badge.removeClass('bump'); }, 500);

                            btn.html('<i class="fa-solid fa-check me-1"></i> Đã thêm');
                            setTimeout(function () {
                                btn.removeClass('is-loading').prop('disabled', false).html(originalHtml);
                            }, 1200);
                            return;
                        }

                        btn.removeClass('is-loading').prop('disabled', false).html(originalHtml);
                    },
                    error: function () {
                        btn.removeClass('is-loading').prop('disabled', false).html(originalHtml);
                    }
                });
            });

            // Wishlist handled globally in layout (delegated) to support dynamic content

            // Compare
            $('.compare-btn').click(function (e) {
                e.preventDefault();
                var productId = $(this).data('product-id');

                $.ajax({
                    url: '@Url.Action("Add", "Compare")',
                    type: 'POST',
                    data: { productId: productId },
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function (response) {
                        alert(response.message);
                        if (response.success) {
                            $('#compareCount').text(response.compareCount);
                        }
                    }
                });
            });
        });
    </script>
}