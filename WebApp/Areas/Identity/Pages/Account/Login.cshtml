@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container py-5 py-md-6">
    <div class="row justify-content-center align-items-center min-vh-75">
        <div class="col-12 col-sm-10 col-md-8 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-dark text-white p-4 p-md-5">
                    <h2 class="fw-bold mb-1">Chào mừng trở lại 👋</h2>
                    <p class="mb-0 text-white-50">Đăng nhập để tiếp tục mua sắm tại TechStore</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label fw-semibold"></label>
                            <input asp-for="Input.Email" class="form-control form-control-lg rounded-3" autocomplete="username" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label fw-semibold"></label>
                            <input asp-for="Input.Password" class="form-control form-control-lg rounded-3" autocomplete="current-password" placeholder="••••••••" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="Input.RememberMe" class="form-check-input" />
                                <label asp-for="Input.RememberMe" class="form-check-label"></label>
                            </div>
                            <a asp-page="./ForgotPassword" class="link-dark text-decoration-none small fw-semibold">
                                Quên mật khẩu?
                            </a>
                        </div>

                        <button type="submit" class="btn btn-dark btn-lg w-100 rounded-3 fw-semibold">
                            Đăng nhập
                        </button>
                    </form>

                    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <div class="d-flex align-items-center my-4">
                            <hr class="flex-grow-1" />
                            <span class="px-3 text-muted small">hoặc tiếp tục với</span>
                            <hr class="flex-grow-1" />
                        </div>

                        <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <button type="submit"
                                    class="btn btn-outline-danger w-100 rounded-3 fw-semibold"
                                    name="provider"
                                    value="Google"
                                    title="Đăng nhập bằng Google">
                                Đăng nhập bằng Google
                            </button>
                        </form>
                    }

                    <p class="text-center text-muted mt-4 mb-0">
                        Chưa có tài khoản?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold link-dark text-decoration-none">
                            Đăng ký ngay
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
