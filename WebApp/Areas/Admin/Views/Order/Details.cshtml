@model Application.DTOs.OrderDto

@{
    ViewData["Title"] = $"Đơn hàng #{Model.Id}";
    var validStatuses = ViewBag.ValidStatuses as List<TechStore.Domain.Enums.OrderStatus> ?? new List<TechStore.Domain.Enums.OrderStatus>();
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h4 class="mb-1"><i class="fa-solid fa-file-invoice me-2"></i>Đơn hàng #@Model.Id</h4>
        <small class="text-muted">
            <i class="fa-solid fa-calendar me-1"></i>Đặt lúc @Model.OrderDate.ToString("HH:mm dd/MM/yyyy")
        </small>
    </div>
    <div class="d-flex align-items-center gap-2">
        <span class="badge @Model.StatusBadgeClass fs-6 px-3 py-2">@Model.StatusDisplay</span>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

<!-- Notifications -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Cột trái: Thông tin -->
    <div class="col-lg-5">
        <!-- Cập nhật trạng thái -->
        @if (validStatuses.Any())
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0"><i class="fa-solid fa-arrows-rotate text-primary me-2"></i>Cập nhật trạng thái</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var nextStatus in validStatuses)
                        {
                            var btnClass = nextStatus switch
                            {
                                TechStore.Domain.Enums.OrderStatus.Confirmed => "btn-info",
                                TechStore.Domain.Enums.OrderStatus.Shipping => "btn-primary",
                                TechStore.Domain.Enums.OrderStatus.Completed => "btn-success",
                                TechStore.Domain.Enums.OrderStatus.Cancelled => "btn-danger",
                                _ => "btn-secondary"
                            };
                            var statusLabel = nextStatus switch
                            {
                                TechStore.Domain.Enums.OrderStatus.Confirmed => "Xác nhận",
                                TechStore.Domain.Enums.OrderStatus.Shipping => "Giao hàng",
                                TechStore.Domain.Enums.OrderStatus.Completed => "Hoàn thành",
                                TechStore.Domain.Enums.OrderStatus.Cancelled => "Hủy đơn",
                                _ => nextStatus.ToString()
                            };
                            var icon = nextStatus switch
                            {
                                TechStore.Domain.Enums.OrderStatus.Confirmed => "fa-circle-check",
                                TechStore.Domain.Enums.OrderStatus.Shipping => "fa-truck",
                                TechStore.Domain.Enums.OrderStatus.Completed => "fa-flag-checkered",
                                TechStore.Domain.Enums.OrderStatus.Cancelled => "fa-ban",
                                _ => "fa-circle"
                            };
                            var confirmMsg = nextStatus == TechStore.Domain.Enums.OrderStatus.Cancelled
                                ? $"Bạn có chắc muốn HỦY đơn hàng #{Model.Id}?"
                                : $"Chuyển đơn #{Model.Id} sang '{statusLabel}'?";

                            <form asp-action="UpdateStatus" method="post" class="d-inline"
                                  onsubmit="return confirm('@confirmMsg')">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="newStatus" value="@nextStatus.ToString()" />
                                <button type="submit" class="btn @btnClass">
                                    <i class="fa-solid @icon me-1"></i>@statusLabel
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-secondary mb-4">
                <i class="fa-solid fa-lock me-2"></i>Đơn hàng đã ở trạng thái cuối, không thể cập nhật.
            </div>
        }

        <!-- Thông tin khách hàng -->
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="fa-solid fa-user text-primary me-2"></i>Thông tin giao hàng</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <small class="text-muted text-uppercase">Người nhận</small>
                    <p class="mb-0 fw-semibold"><i class="fa-solid fa-user me-2 text-muted"></i>@Model.FullName</p>
                </div>
                <div class="mb-3">
                    <small class="text-muted text-uppercase">Số điện thoại</small>
                    <p class="mb-0 fw-semibold"><i class="fa-solid fa-phone me-2 text-muted"></i>@Model.PhoneNumber</p>
                </div>
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div class="mb-3">
                        <small class="text-muted text-uppercase">Email</small>
                        <p class="mb-0 fw-semibold"><i class="fa-solid fa-envelope me-2 text-muted"></i>@Model.Email</p>
                    </div>
                }
                <div class="mb-3">
                    <small class="text-muted text-uppercase">Địa chỉ</small>
                    <p class="mb-0 fw-semibold"><i class="fa-solid fa-location-dot me-2 text-muted"></i>@Model.ShippingAddress</p>
                </div>
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="mb-3">
                        <small class="text-muted text-uppercase">Ghi chú</small>
                        <p class="mb-0"><i class="fa-solid fa-note-sticky me-2 text-muted"></i>@Model.Note</p>
                    </div>
                }
                <div>
                    <small class="text-muted text-uppercase">Thanh toán</small>
                    <p class="mb-0">
                        <i class="fa-solid fa-credit-card me-2 text-muted"></i>
                        <span class="badge bg-info">@Model.PaymentMethodDisplay</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Cột phải: Sản phẩm -->
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="fa-solid fa-box text-warning me-2"></i>Sản phẩm (@Model.Items.Count)</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px;"></th>
                            <th>Sản phẩm</th>
                            <th class="text-center" style="width:80px;">SL</th>
                            <th class="text-end" style="width:120px;">Đơn giá</th>
                            <th class="text-end" style="width:130px;">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <img src="@(item.ImageUrl ?? "https://via.placeholder.com/44")"
                                         class="rounded border" style="width:44px;height:44px;object-fit:contain;">
                                </td>
                                <td>
                                    <a asp-area="" asp-controller="Home" asp-action="Detail" asp-route-id="@item.ProductId"
                                       class="fw-semibold text-decoration-none" target="_blank">
                                        @item.ProductName
                                    </a>
                                </td>
                                <td class="text-center">×@item.Quantity</td>
                                <td class="text-end">@item.Price.ToString("#,##0")₫</td>
                                <td class="text-end fw-bold text-danger">@item.Total.ToString("#,##0")₫</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- Tổng tiền -->
                <div class="p-3 bg-light border-top">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Tạm tính (@Model.Items.Count sản phẩm):</span>
                        <span>@Model.TotalAmount.ToString("#,##0")₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Phí vận chuyển:</span>
                        <span class="text-success">Miễn phí</span>
                    </div>
                    <hr class="my-2">
                    <div class="d-flex justify-content-between">
                        <strong class="fs-5">Tổng cộng:</strong>
                        <strong class="fs-4 text-danger">@Model.TotalAmount.ToString("#,##0")₫</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
