@model IEnumerable<Application.DTOs.Admin.AdminVoucherDto>
@using TechStore.Domain.Enums

@{
    ViewData["Title"] = "Quản lý voucher";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="fa-solid fa-ticket me-2"></i>Quản lý voucher</h4>
        <small class="text-muted">Tổng cộng <strong>@Model.Count()</strong> voucher</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Thêm voucher
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    @if (!Model.Any())
    {
        <div class="card-body text-center py-5">
            <i class="fa-solid fa-ticket fa-3x text-muted mb-3"></i>
            <h5 class="text-muted">Chưa có voucher nào</h5>
            <a asp-action="Create" class="btn btn-primary mt-2">
                <i class="fa-solid fa-plus me-1"></i>Tạo voucher đầu tiên
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã</th>
                        <th>Loại</th>
                        <th>Giá trị</th>
                        <th>Điều kiện</th>
                        <th>Hiệu lực</th>
                        <th class="text-center">Lượt dùng</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width:170px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model)
                    {
                        var isExpired = DateTime.Now > v.EndAt;
                        <tr>
                            <td>
                                <div class="fw-semibold">@v.Code</div>
                                @if (!string.IsNullOrWhiteSpace(v.Description))
                                {
                                    <small class="text-muted">@v.Description</small>
                                }
                            </td>
                            <td>
                                @(v.Type == VoucherType.Percentage ? "Phần trăm" : "Số tiền")
                            </td>
                            <td>
                                @if (v.Type == VoucherType.Percentage)
                                {
                                    <span>@v.Value.ToString("0.##")%</span>
                                    @if (v.MaxDiscountAmount.HasValue)
                                    {
                                        <br />
                                        <small class="text-muted">Tối đa @v.MaxDiscountAmount.Value.ToString("#,##0")₫</small>
                                    }
                                }
                                else
                                {
                                    <span>@v.Value.ToString("#,##0")₫</span>
                                }
                            </td>
                            <td>Đơn từ @v.MinOrderAmount.ToString("#,##0")₫</td>
                            <td>
                                <small class="d-block">Từ: @v.StartAt.ToString("dd/MM/yyyy HH:mm")</small>
                                <small class="d-block">Đến: @v.EndAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </td>
                            <td class="text-center">
                                @if (v.UsageLimit.HasValue)
                                {
                                    <span class="badge bg-primary">@v.UsedCount / @v.UsageLimit</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@v.UsedCount / ∞</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (!v.IsActive)
                                {
                                    <span class="badge bg-secondary">Đang tắt</span>
                                }
                                else if (isExpired)
                                {
                                    <span class="badge bg-warning text-dark">Hết hạn</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Đang bật</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-outline-primary" title="Sửa">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>

                                    @if (v.IsActive)
                                    {
                                        <form asp-action="Deactivate" asp-route-id="@v.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Tắt voucher @v.Code?')">
                                            <button type="submit" class="btn btn-outline-warning" title="Tắt">
                                                <i class="fa-solid fa-toggle-off"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Activate" asp-route-id="@v.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Kích hoạt voucher @v.Code?')">
                                            <button type="submit" class="btn btn-outline-success" title="Bật">
                                                <i class="fa-solid fa-toggle-on"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>