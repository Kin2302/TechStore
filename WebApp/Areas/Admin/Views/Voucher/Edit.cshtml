@model Application.DTOs.Admin.AdminVoucherDto
@using TechStore.Domain.Enums

@{
    ViewData["Title"] = "Sửa voucher";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fa-solid fa-arrow-left"></i>
    </a>
    <h4 class="mb-0"><i class="fa-solid fa-pen me-2"></i>Sửa voucher</h4>
</div>

<div class="card shadow-sm border-0" style="max-width:760px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Code" class="form-label fw-semibold"></label>
                    <input asp-for="Code" class="form-control" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Type" class="form-label fw-semibold"></label>
                    <select asp-for="Type" class="form-select" id="voucherType">
                        <option value="@VoucherType.FixedAmount">Số tiền cố định</option>
                        <option value="@VoucherType.Percentage">Phần trăm (%)</option>
                    </select>
                    <span asp-validation-for="Type" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Value" class="form-label fw-semibold"></label>
                    <input asp-for="Value" class="form-control" />
                    <span asp-validation-for="Value" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="MinOrderAmount" class="form-label fw-semibold"></label>
                    <input asp-for="MinOrderAmount" class="form-control" />
                    <span asp-validation-for="MinOrderAmount" class="text-danger small"></span>
                </div>

                <div class="col-md-4" id="maxDiscountWrap">
                    <label asp-for="MaxDiscountAmount" class="form-label fw-semibold"></label>
                    <input asp-for="MaxDiscountAmount" class="form-control" />
                    <span asp-validation-for="MaxDiscountAmount" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="StartAt" class="form-label fw-semibold"></label>
                    <input asp-for="StartAt" type="datetime-local" class="form-control" />
                    <span asp-validation-for="StartAt" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="EndAt" class="form-label fw-semibold"></label>
                    <input asp-for="EndAt" type="datetime-local" class="form-control" />
                    <span asp-validation-for="EndAt" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="UsageLimit" class="form-label fw-semibold"></label>
                    <input asp-for="UsageLimit" class="form-control" />
                    <span asp-validation-for="UsageLimit" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="MaxUsagePerUser" class="form-label fw-semibold"></label>
                    <input asp-for="MaxUsagePerUser" class="form-control" />
                    <span asp-validation-for="MaxUsagePerUser" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Đã dùng</label>
                    <input value="@Model.UsedCount" class="form-control" readonly />
                </div>

                <div class="col-12">
                    <div class="form-check mt-2">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        const voucherType = document.getElementById("voucherType");
        const maxDiscountWrap = document.getElementById("maxDiscountWrap");

        function toggleMaxDiscount() {
            const isPercentage = voucherType.value.includes("Percentage");
            maxDiscountWrap.style.display = isPercentage ? "" : "none";
        }

        voucherType?.addEventListener("change", toggleMaxDiscount);
        toggleMaxDiscount();
    </script>
}