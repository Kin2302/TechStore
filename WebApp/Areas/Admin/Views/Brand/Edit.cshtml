@model Application.DTOs.Catalog.BrandDto

@{
    ViewData["Title"] = "Sửa thương hiệu";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fa-solid fa-arrow-left"></i>
    </a>
    <h4 class="mb-0"><i class="fa-solid fa-pen me-2"></i>Sửa thương hiệu</h4>
</div>

<div class="card shadow-sm border-0" style="max-width:580px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Tên thương hiệu <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Origin" class="form-label fw-semibold">Xuất xứ</label>
                <input asp-for="Origin" class="form-control" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Logo thương hiệu</label>
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <div class="mb-2">
                        <img id="logoPreview" src="@Model.LogoUrl" alt="@Model.Name"
                             class="rounded border" style="height:80px;object-fit:contain;">
                    </div>
                }
                else
                {
                    <img id="logoPreview" src="#" alt="Preview"
                         class="d-none rounded border mb-2" style="height:80px;object-fit:contain;">
                }
                <input type="file" name="logoFile" class="form-control" accept="image/*"
                       onchange="previewLogo(this)" />
                <div class="form-text">Để trống nếu không muốn thay đổi logo.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewLogo(input) {
            const img = document.getElementById('logoPreview');
            if (input.files && input.files[0]) {
                img.src = URL.createObjectURL(input.files[0]);
                img.classList.remove('d-none');
            }
        }
    </script>
}