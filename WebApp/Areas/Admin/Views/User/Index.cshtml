@model List<Application.DTOs.Admin.UserInfoDto>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="fa-solid fa-users-gear me-2"></i>Quản lý người dùng</h4>
        <small class="text-muted">Tổng cộng <strong>@Model.Count</strong> tài khoản</small>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Email</th>
                    <th>Tên đăng nhập</th>
                    <th class="text-center">Đơn hàng</th>
                    <th class="text-end">Tổng chi tiêu</th>
                    <th style="width:220px;">Quyền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-semibold">@user.Email</td>
                        <td>@user.UserName</td>
                        <td class="text-center">@user.TotalOrders</td>
                        <td class="text-end text-danger fw-semibold">@user.TotalSpent.ToString("#,##0")₫</td>
                        <td>
                            <form asp-action="UpdateRole" method="post" class="d-flex gap-2">
                                <input type="hidden" name="userId" value="@user.UserId" />
                                <select name="role" class="form-select form-select-sm">
                                    @if (user.Role == "Admin")
                                    {
                                        <option value="User">User</option>
                                        <option value="Admin" selected>Admin</option>
                                    }
                                    else
                                    {
                                        <option value="User" selected>User</option>
                                        <option value="Admin">Admin</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-primary">
                                    <i class="fa-solid fa-floppy-disk"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
