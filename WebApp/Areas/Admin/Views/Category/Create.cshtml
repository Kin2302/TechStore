@model Application.DTOs.CategoryDto

@{
    ViewData["Title"] = "Thêm danh mục";
    var parents = ViewBag.ParentCategories as IEnumerable<Application.DTOs.CategoryDto>
        ?? Enumerable.Empty<Application.DTOs.CategoryDto>();
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fa-solid fa-arrow-left"></i>
    </a>
    <h4 class="mb-0"><i class="fa-solid fa-folder-plus me-2"></i>Thêm danh mục mới</h4>
</div>

<div class="card shadow-sm border-0" style="max-width:680px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Tên danh mục <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="VD: Board Phát Triển" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Slug" class="form-label fw-semibold">Slug</label>
                <input asp-for="Slug" class="form-control" placeholder="VD: board-phat-trien (tự tạo nếu để trống)" />
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Mô tả ngắn về danh mục..."></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="IconUrl" class="form-label fw-semibold">Icon (Font Awesome class)</label>
                <input asp-for="IconUrl" class="form-control" placeholder="VD: fa-solid fa-microchip" />
                <div class="form-text">Nhập class Font Awesome để hiển thị icon.</div>
            </div>

            <div class="mb-4">
                <label asp-for="ParentId" class="form-label fw-semibold">Danh mục cha</label>
                <select asp-for="ParentId" class="form-select">
                    <option value="">-- Không có (danh mục gốc) --</option>
                    @foreach (var p in parents)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Lưu danh mục
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}