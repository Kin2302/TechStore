@model Application.DTOs.Catalog.CouponDto

@{
    ViewData["Title"] = "Sửa phiếu giảm giá";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">Quay lại</a>
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="card shadow-sm p-4">
        <div class="mb-3">
            <label class="form-label">Mã (code)</label>
            <input asp-for="Code" class="form-control" />
        </div>
        <div class="mb-3 row">
            <div class="col-md-6">
                <label class="form-label">Loại</label>
                <select asp-for="IsPercent" class="form-select">
                    <option value="true">Phần trăm</option>
                    <option value="false">Tiền</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Giá trị</label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
            </div>
        </div>
        <div class="mb-3 row">
            <div class="col-md-6">
                <label class="form-label">Bắt đầu</label>
                <input asp-for="StartDate" class="form-control" type="date" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Kết thúc</label>
                <input asp-for="EndDate" class="form-control" type="date" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Giới hạn số lần sử dụng (null = không giới hạn)</label>
            <input asp-for="UsageLimit" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>
        <div class="mb-3 form-check">
            <input asp-for="IsActive" class="form-check-input" />
            <label class="form-check-label">Kích hoạt</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </div>
</form>
