@model Application.DTOs.DashboardDto

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Admin Dashboard</h1>
<p>Nếu thấy trang này = Area hoạt động!</p>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="fa-solid fa-box"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold">@Model.TotalOrders</h3>
                    <small class="text-muted">Tổng đơn hàng</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="fa-solid fa-clock"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold">@Model.PendingOrders</h3>
                    <small class="text-muted">Chờ xử lý</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="fa-solid fa-money-bill-trend-up"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold">@Model.TotalRevenue.ToString("#,##0")₫</h3>
                    <small class="text-muted">Doanh thu (Completed)</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="fa-solid fa-tags"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold">@Model.TotalProducts</h3>
                    <small class="text-muted">Sản phẩm</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Order Status Overview -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-body py-3">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h6 class="mb-0"><i class="fa-solid fa-chart-pie me-2"></i>Phân bố trạng thái</h6>
                    <div class="d-flex gap-3 flex-wrap">
                        <a asp-controller="Order" asp-action="Index" asp-route-status="Pending" class="text-decoration-none">
                            <span class="badge bg-warning text-dark px-3 py-2">
                                <i class="fa-solid fa-clock me-1"></i>Chờ xác nhận: @Model.PendingOrders
                            </span>
                        </a>
                        <a asp-controller="Order" asp-action="Index" asp-route-status="Confirmed" class="text-decoration-none">
                            <span class="badge bg-info px-3 py-2">
                                <i class="fa-solid fa-circle-check me-1"></i>Đã xác nhận: @Model.ConfirmedOrders
                            </span>
                        </a>
                        <a asp-controller="Order" asp-action="Index" asp-route-status="Shipping" class="text-decoration-none">
                            <span class="badge bg-primary px-3 py-2">
                                <i class="fa-solid fa-truck me-1"></i>Đang giao: @Model.ShippingOrders
                            </span>
                        </a>
                        <span class="badge bg-success px-3 py-2">
                            <i class="fa-solid fa-flag-checkered me-1"></i>Hoàn thành: @Model.CompletedOrders
                        </span>
                        <span class="badge bg-danger px-3 py-2">
                            <i class="fa-solid fa-ban me-1"></i>Đã hủy: @Model.CancelledOrders
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Extra Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="fa-solid fa-calendar-day"></i>
                </div>
                <div>
                    <h5 class="mb-0 fw-bold">@Model.TodayRevenue.ToString("#,##0")₫</h5>
                    <small class="text-muted">Doanh thu hôm nay</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div>
                    <h5 class="mb-0 fw-bold">@Model.LowStockProducts</h5>
                    <small class="text-muted">Sản phẩm sắp hết hàng (≤ 5)</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Đơn hàng gần đây -->
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="fa-solid fa-clock-rotate-left me-2"></i>Đơn hàng gần đây</h6>
                <a asp-controller="Order" asp-action="Index" class="btn btn-sm btn-outline-primary">
                    Xem tất cả <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentOrders.Any())
                {
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Khách hàng</th>
                                <th class="text-end">Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th>Ngày</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id"
                                           class="fw-bold text-decoration-none">#@order.Id</a>
                                    </td>
                                    <td>
                                        <span class="fw-semibold">@order.FullName</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="fw-bold text-danger">@order.TotalAmount.ToString("#,##0")₫</span>
                                    </td>
                                    <td>
                                        <span class="badge @order.StatusBadgeClass rounded-pill">@order.StatusDisplay</span>
                                    </td>
                                    <td>
                                        <small class="text-muted">@order.OrderDate.ToString("dd/MM HH:mm")</small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-inbox fa-2x mb-2"></i>
                        <p class="mb-0">Chưa có đơn hàng nào</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- SP bán chạy -->
    <div class="col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h6 class="mb-0"><i class="fa-solid fa-fire text-danger me-2"></i>Sản phẩm bán chạy</h6>
            </div>
            <div class="card-body p-0">
                @if (Model.TopProducts.Any())
                {
                    <div class="list-group list-group-flush">
                        @{ var rank = 1; }
                        @foreach (var product in Model.TopProducts)
                        {
                            <div class="list-group-item d-flex align-items-center gap-3 py-3">
                                <span class="badge rounded-circle @(rank <= 3 ? "bg-warning text-dark" : "bg-secondary")"
                                      style="width:28px;height:28px;display:flex;align-items:center;justify-content:center;font-weight:700;">
                                    @rank
                                </span>
                                <img src="@(product.ImageUrl ?? "https://via.placeholder.com/40")"
                                     class="rounded border" style="width:40px;height:40px;object-fit:contain;">
                                <div class="flex-grow-1">
                                    <a asp-area="" asp-controller="Home" asp-action="Detail" asp-route-id="@product.ProductId"
                                       class="fw-semibold text-decoration-none d-block text-truncate" style="max-width:180px;"
                                       target="_blank">
                                        @product.ProductName
                                    </a>
                                    <small class="text-muted">Doanh thu: @product.Revenue.ToString("#,##0")₫</small>
                                </div>
                                <span class="badge bg-success rounded-pill">@product.TotalSold sold</span>
                            </div>
                            rank++;
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-chart-bar fa-2x mb-2"></i>
                        <p class="mb-0">Chưa có dữ liệu bán hàng</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
